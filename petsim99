    local args = {[1] = "Roblox", [2] = "Test", [3] = "Pet", [4] = uid, [5] = 1}  
    local success, result = pcall(function()  
        return {network:WaitForChild("Mailbox: Send"):InvokeServer(unpack(args))}  
