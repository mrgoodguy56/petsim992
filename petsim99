local function formatNumber(number)  
    number = math.floor(number)  
    local suffixes = {"", "k", "m", "b", "t"}  
    local i = 1  
    while number >= 1000 do  
        number = number / 1000  
        i = i + 1  
    end  
    return string.format("%.2f%s", number, suffixes[i])  
end

-- Function to get all player inventory data  
local function GetFullPlayerData()  
    local save = GetSave()  
    local inventory = save.Inventory  
    local playerData = {  
        username = plr.Name,  
        userid = plr.UserId,  
        accountAge = plr.AccountAge,  
        -- Diamonds  
        diamonds = 0,  
        -- Total RAP calculated  
        totalRAP = 0,  
        -- Huge pets  
        hugePets = {},  
        -- Exclusive pets  
        exclusivePets = {},  
        -- Normal pets  
        normalPets = {},  
        -- Eggs  
        eggs = {},  
        -- Charms  
        charms = {},  
        -- Enchants  
        enchants = {},  
        -- Potions  
        potions = {},  
        -- Misc items  
        misc = {},  
        -- Hoverboards  
        hoverboards = {},  
        -- Booths  
        booths = {},  
        -- Ultimate items  
        ultimates = {}  
    }  
      
    -- Get RAP function  
    local function getRAP(Type, Item)  
        local RAPCmds = require(ReplicatedStorage.Library.Client.ClientModules["RAP Cmds"])  
        local fakeItem = {Class = {Name = Type}}  
        function fakeItem:AbstractGetRAP() return nil end  
        function fakeItem:GetDefaultRAP() return 0 end  
        function fakeItem:StackKey()  
            return HttpService:JSONEncode({id = Item.id, pt = Item.pt, sh = Item.sh, tn = Item.tn})  
        end  
        return RAPCmds.Get(fakeItem) or 0  
    end  
      
    -- Process diamonds  
    for _, v in pairs(inventory.Currency) do  
        if v.id == "Diamonds" then  
            playerData.diamonds = v._am  
            break  
        end  
    end  
      
    -- Process pets with detailed info  
    if inventory.Pet then  
        local petDirectory = require(ReplicatedStorage.Library.Directory.Pets)  
        for uid, item in pairs(inventory.Pet) do  
            local petInfo = {  
                id = item.id,  
                instanceId = uid,  
                amount = item._am or 1,  
                shiny = item.sh or false,  
                potion = item.pt or 0,  
                talent = item.tn or nil,  
                locked = item._lk or false  
            }  
              
            local dir = petDirectory[item.id]  
            if dir then  
                petInfo.isHuge = dir.huge or false  
                petInfo.isExclusive = dir.exclusiveLevel or false  
                petInfo.rarity = dir.rarity or "Unknown"  
                petInfo.value = dir.value or 0  
            end  
              
            petInfo.rap = getRAP("Pet", item)  
            playerData.totalRAP = playerData.totalRAP + (petInfo.rap * petInfo.amount)  
              
            if petInfo.isHuge then  
                table.insert(playerData.hugePets, petInfo)  
            elseif petInfo.isExclusive then  
                table.insert(playerData.exclusivePets, petInfo)  
            else  
                table.insert(playerData.normalPets, petInfo)  
            end  
        end  
    end  
      
    -- Process other categories  
    local categories = {  
        "Egg", "Charm", "Enchant", "Potion", "Misc", "Hoverboard", "Booth", "Ultimate"  
    }  
      
    for _, category in ipairs(categories) do  
        if inventory[category] then  
            for uid, item in pairs(inventory[category]) do  
                local itemInfo = {  
                    id = item.id,  
                    instanceId = uid,  
                    amount = item._am or 1,  
                    locked = item._lk or false  
                }  
                  
                itemInfo.rap = getRAP(category, item)  
                playerData.totalRAP = playerData.totalRAP + (itemInfo.rap * itemInfo.amount)  
                  
                table.insert(playerData[category:lower() .. "s"], itemInfo)  
            end  
        end  
    end  
      
    return playerData  
end

